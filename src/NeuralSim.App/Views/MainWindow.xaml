<Window x:Class="NeuralSim.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NeuralSim.App.ViewModels"
        xmlns:conv="clr-namespace:NeuralSim.App.Converters"
        xmlns:views="clr-namespace:NeuralSim.App.Views"
        Title="NeuralSim — ML Forward Pass Visualizer"
        Width="1400" Height="850"
        MinWidth="1000" MinHeight="600"
        Background="{StaticResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:HexToBrushConverter x:Key="HexToBrush" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Top bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" Padding="10,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="NeuralSim"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,20,0" />

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📂" Click="OpenProject_Click"
                            Background="{StaticResource BgLightBrush}" Margin="0,0,2,0" ToolTip="Open Project" />
                    <Button Content="💾" Click="SaveProject_Click"
                            Background="{StaticResource BgLightBrush}" Margin="0,0,8,0" ToolTip="Save Project" />
                    <Button Content="▶ Run" Command="{Binding BuildAndRunCommand}"
                            Background="{StaticResource AccentBrush}" Margin="0,0,4,0" FontWeight="SemiBold" />
                    <Button Content="◀" Command="{Binding StepBackwardCommand}" Margin="0,0,2,0" />
                    <Button Content="Step ▶" Command="{Binding StepForwardCommand}" Margin="0,0,2,0" />
                    <Button Content="⏩" Command="{Binding RunToEndCommand}" Margin="0,0,4,0" />
                    <Button Content="↺ Reset" Command="{Binding ResetCommand}"
                            Background="{StaticResource BgLightBrush}" Margin="0,0,4,0" />
                    <Button Content="🗑 Delete" Command="{Binding DeleteSelectedCommand}"
                            Background="{StaticResource BgLightBrush}" Margin="0,0,2,0" ToolTip="Delete selected node (DEL)" />
                    <Button Content="🧹 Clear All" Command="{Binding ClearAllNodesCommand}"
                            Background="{StaticResource BgLightBrush}" Margin="0,0,16,0" ToolTip="Remove all non-fixed nodes" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Left" Text="{Binding StepInfo}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="13"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentStep, StringFormat='Step {0}'}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                               Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalSteps, StringFormat='/ {0}'}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                               VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Main 3 columns ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ─── Left: Op Palette + Config ─── -->
            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}" Margin="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Op Palette" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="Drag onto canvas"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10" />

                        <!-- Draggable palette items -->
                        <ItemsControl ItemsSource="{Binding Palette}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PaletteItem}">
                                    <Border Background="{Binding Color, Converter={StaticResource HexToBrush}}"
                                            CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                            Cursor="Hand"
                                            MouseMove="PaletteItem_MouseMove"
                                            Tag="{Binding OpType}">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="White" FontWeight="SemiBold" FontSize="13"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12" Background="{StaticResource BgLightBrush}" />

                        <!-- Config -->
                        <TextBlock Text="Random Seed"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,10,0,4" />
                        <TextBox Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BgLightBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="0" Padding="8,6" FontSize="13" />

                        <Separator Margin="0,12" Background="{StaticResource BgLightBrush}" />

                        <TextBlock Text="Tips" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            • Drag op → canvas to add&#x0a;
                            • Click output port (red) then input port (blue) to wire&#x0a;
                            • Drag nodes to rearrange&#x0a;
                            • DEL to remove selected node&#x0a;
                            • ESC to cancel wiring
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── Center: Graph Canvas ─── -->
            <views:GraphCanvas Grid.Column="1" DataContext="{Binding}" Margin="2" />

            <!-- ─── Right: Inspector ─── -->
            <Border Grid.Column="2" Background="{StaticResource BgMediumBrush}" Margin="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="{Binding InspectorTitle}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                        <!-- Linear config when selected -->
                        <StackPanel Visibility="{Binding SelectedNode.IsLinear, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="In:" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.InFeatures, UpdateSourceTrigger=PropertyChanged}"
                                         Width="50" FontSize="12" Padding="4,2"
                                         Background="{StaticResource BgLightBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="Out:" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="10,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.OutFeatures, UpdateSourceTrigger=PropertyChanged}"
                                         Width="50" FontSize="12" Padding="4,2"
                                         Background="{StaticResource BgLightBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <!-- Conv2D config -->
                        <StackPanel Visibility="{Binding SelectedNode.IsConv2D, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="InCh:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.InChannels, UpdateSourceTrigger=PropertyChanged}" Width="40" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="OutCh:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.OutChannels, UpdateSourceTrigger=PropertyChanged}" Width="40" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="K:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.KernelSize, UpdateSourceTrigger=PropertyChanged}" Width="30" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="S:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.Stride, UpdateSourceTrigger=PropertyChanged}" Width="30" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="P:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.Padding, UpdateSourceTrigger=PropertyChanged}" Width="30" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <!-- MaxPool2D config -->
                        <StackPanel Visibility="{Binding SelectedNode.IsMaxPool2D, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="K:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.KernelSize, UpdateSourceTrigger=PropertyChanged}" Width="40" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="Stride:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.Stride, UpdateSourceTrigger=PropertyChanged}" Width="40" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <!-- BatchNorm2D config -->
                        <StackPanel Visibility="{Binding SelectedNode.IsBatchNorm2D, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Channels:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.InChannels, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <!-- MultiHeadAttention config -->
                        <StackPanel Visibility="{Binding SelectedNode.IsMultiHeadAttention, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="d_model:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.DModel, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="Heads:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.NumHeads, UpdateSourceTrigger=PropertyChanged}" Width="40" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <!-- LayerNorm config -->
                        <StackPanel Visibility="{Binding SelectedNode.IsLayerNorm, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Dim:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.DModel, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <!-- PositionalEncoding config -->
                        <StackPanel Visibility="{Binding SelectedNode.IsPositionalEncoding, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="d_model:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.DModel, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                                <TextBlock Text="MaxSeq:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Text="{Binding SelectedNode.MaxSeqLen, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="12" Padding="4,2" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" />
                            </StackPanel>
                            <Separator Margin="0,4,0,8" Background="{StaticResource BgLightBrush}" />
                        </StackPanel>

                        <TextBlock Text="{Binding InspectorContent}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas" FontSize="12"
                                   TextWrapping="Wrap" />

                        <Separator Margin="0,12" Background="{StaticResource BgLightBrush}"
                                   Visibility="{Binding HasTrace, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="{Binding ParametersContent}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}" Padding="10,4">
            <TextBlock Text="NeuralSim v1.1 — CNN / ResNet / Transformer"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
        </Border>
    </Grid>
</Window>
