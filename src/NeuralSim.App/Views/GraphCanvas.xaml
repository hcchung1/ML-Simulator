<UserControl x:Class="NeuralSim.App.Views.GraphCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NeuralSim.App.ViewModels"
             xmlns:conv="clr-namespace:NeuralSim.App.Converters"
             xmlns:views="clr-namespace:NeuralSim.App.Views"
             Background="#1E1E2E" AllowDrop="True"
             Drop="OnDrop" DragOver="OnDragOver">

    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
        <conv:HexToBrushConverter x:Key="HexToBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <views:StringToVisConverter x:Key="StrToVis" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="CanvasScroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="OnPreviewMouseWheel"
                      Background="Transparent">
            <Grid x:Name="RootGrid" Width="5000" Height="5000">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}" />
                </Grid.LayoutTransform>
        <!-- Edges layer (behind nodes) -->
        <ItemsControl x:Name="EdgesLayer" ItemsSource="{Binding Connections}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                    <Canvas>
                        <Line X1="{Binding X1}" Y1="{Binding Y1}"
                              X2="{Binding X2}" Y2="{Binding Y2}"
                              Stroke="#88AAAACC" StrokeThickness="2.5"
                              StrokeDashArray="4 2" />
                        <!-- Arrowhead at target -->
                        <Polygon Points="-6,-6 6,-6 0,4"
                                 Fill="#88AAAACC"
                                 Canvas.Left="{Binding X2}" Canvas.Top="{Binding Y2}">
                            <Polygon.RenderTransform>
                                <TranslateTransform X="-0" Y="-4" />
                            </Polygon.RenderTransform>
                        </Polygon>
                    </Canvas>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Nodes layer -->
        <ItemsControl x:Name="NodesLayer" ItemsSource="{Binding CanvasNodes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:CanvasNodeViewModel}">
                    <Grid Width="180" MouseLeftButtonDown="Node_MouseLeftButtonDown"
                          MouseMove="Node_MouseMove" MouseLeftButtonUp="Node_MouseLeftButtonUp"
                          Tag="{Binding}">
                        <!-- Input port (top center) -->
                        <Ellipse Width="14" Height="14"
                                 Fill="#1565C0" Stroke="White" StrokeThickness="1.5"
                                 HorizontalAlignment="Center" VerticalAlignment="Top"
                                 Margin="0,-7,0,0" Cursor="Cross"
                                 Visibility="{Binding InputPortNames.Count, Converter={StaticResource StrToVis}}"
                                 MouseLeftButtonDown="InputPort_Click" Tag="{Binding}" />

                        <!-- Node body -->
                        <Border Background="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                CornerRadius="8" Padding="10,8" MinHeight="44"
                                Margin="0,4,0,4"
                                BorderBrush="{Binding BlockColor, Converter={StaticResource HexToBrush}}"
                                BorderThickness="2" Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="White" FontWeight="SemiBold" FontSize="13"
                                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding OpType}"
                                           Foreground="#B0B0C0" FontSize="10" HorizontalAlignment="Center" />
                                <!-- Editable input vector (only for Input node) -->
                                <TextBox Text="{Binding DataContext.InputText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding IsGraphInput, Converter={StaticResource BoolToVis}}"
                                         Background="#2A2A40" Foreground="#FFD54F" FontSize="11"
                                         BorderThickness="0" Padding="4,3" Margin="0,4,0,0"
                                         TextWrapping="Wrap" AcceptsReturn="False"
                                         ToolTip="Comma-separated input values" />
                                <TextBlock Text="{Binding OutputSummary}"
                                           Foreground="#FFD54F" FontSize="10" HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding OutputSummary, Converter={StaticResource StrToVis}}" />
                            </StackPanel>
                        </Border>

                        <!-- Output port (bottom center) -->
                        <Ellipse Width="14" Height="14"
                                 Fill="#C62828" Stroke="White" StrokeThickness="1.5"
                                 HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                 Margin="0,0,0,-7" Cursor="Cross"
                                 Visibility="{Binding OutputPortNames.Count, Converter={StaticResource StrToVis}}"
                                 MouseLeftButtonDown="OutputPort_Click" Tag="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

            </Grid>
        </ScrollViewer>

        <!-- Wiring indicator (overlay, not affected by scroll/zoom) -->
        <TextBlock x:Name="WiringLabel"
                   Text="Click a port to complete connection (ESC to cancel)"
                   Foreground="#FFD54F" FontSize="12" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,10"
                   IsHitTestVisible="False"
                   Visibility="Collapsed" />
    </Grid>
</UserControl>
